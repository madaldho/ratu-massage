---
const waLink = 'https://wa.me/628892286721?text=Halo%2C%20saya%20mau%20klaim%20promo%20diskon%2020%25%20untuk%20booking%20pertama';
---

<section class="promo" id="promo">
  <div class="container">
    <div class="promo-box reveal">
      <div class="promo-text">
        <h2>Diskon 20% Booking Pertama</h2>
        <p>Rasakan pengalaman massage premium dengan harga spesial. Berlaku untuk semua jenis layanan.</p>
      </div>
      <a href={waLink} class="btn-promo" target="_blank" rel="noopener noreferrer">Klaim Promo</a>
    </div>
  </div>
</section>

<style>
  .promo {
    padding: 56px 0;
  }
  .promo-box {
    background: var(--cream);
    border-left: 3px solid var(--gold);
    border-radius: 4px;
    padding: 48px 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }
  .promo-text h2 {
    font-size: 1.8rem;
    margin-bottom: 8px;
  }
  .promo-text p {
    font-size: 0.92rem;
    max-width: 440px;
  }
  .btn-promo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--gold);
    color: var(--white);
    padding: 14px 32px;
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: all 0.3s ease;
    border: none;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .btn-promo:hover,
  .btn-promo:focus-visible {
    background: var(--gold-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212, 165, 74, 0.35);
  }

  @media (max-width: 900px) {
    .promo-box {
      flex-direction: column;
      align-items: flex-start;
      padding: 36px 32px;
    }
  }
  @media (max-width: 480px) {
    .promo-box {
      padding: 28px 24px;
    }
  }
</style>
