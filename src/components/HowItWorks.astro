---
const steps = [
  {
    num: '1',
    title: 'Hubungi via WhatsApp',
    desc: 'Klik tombol booking atau chat kami langsung untuk konsultasi.',
  },
  {
    num: '2',
    title: 'Pilih Layanan & Jadwal',
    desc: 'Tentukan jenis massage, waktu, dan lokasi Anda.',
  },
  {
    num: '3',
    title: 'Terapis Tiba di Lokasi',
    desc: 'Terapis datang tepat waktu dengan perlengkapan lengkap.',
  },
];
---

<section class="section section--white" id="cara-pesan">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-label">Cara Pemesanan</div>
      <h2 class="section-title">Tiga Langkah Mudah</h2>
      <p class="section-desc">Tanpa ribet, terapis profesional kami langsung datang ke lokasi Anda.</p>
    </div>
    <div class="steps-row">
      <div class="steps-line"></div>
      {steps.map((s) => (
        <div class="step reveal">
          <div class="step-number">{s.num}</div>
          <div class="step-text">
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .steps-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    position: relative;
    max-width: 820px;
    margin: 0 auto;
  }
  .steps-line {
    position: absolute;
    top: 26px;
    left: calc(16.67% + 26px);
    right: calc(16.67% + 26px);
    height: 1px;
    background: rgba(212, 165, 74, 0.3);
    z-index: 0;
  }
  .step {
    text-align: center;
    position: relative;
    z-index: 1;
    padding: 0 8px;
    transition: transform 0.3s ease;
  }
  .step:hover {
    transform: translateY(-4px);
  }
  .step-number {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--gold);
    width: 52px;
    height: 52px;
    border: 1.5px solid var(--gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    background: var(--white);
    transition: background 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }
  .step:hover .step-number {
    background: var(--gold);
    color: var(--white);
    transform: scale(1.1);
  }
  .step h3 {
    font-size: 1.05rem;
    margin-bottom: 6px;
  }
  .step p {
    font-size: 0.84rem;
    line-height: 1.65;
    max-width: 220px;
    margin: 0 auto;
    color: var(--gray);
  }
  .step-text {
    /* wrapper for mobile layout */
  }

  @media (max-width: 768px) {
    .steps-row {
      grid-template-columns: 1fr;
      gap: 28px;
      max-width: 340px;
    }
    .steps-line { display: none; }
    .step {
      display: flex;
      text-align: left;
      align-items: flex-start;
      gap: 16px;
      padding: 0;
    }
    .step-number {
      margin: 0;
      flex-shrink: 0;
      width: 44px;
      height: 44px;
      font-size: 1.2rem;
    }
    .step p {
      max-width: 100%;
    }
  }
</style>
