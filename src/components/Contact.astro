---
const waLink = 'https://wa.me/628892286721?text=Halo%20Ratu%20Massage%2C%20saya%20mau%20tanya-tanya%20dulu';
const mapsLink = 'https://maps.google.com/?cid=8466421730057760274';
---

<section class="section section--white" id="kontak">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-label">Kontak</div>
      <h2 class="section-title">Hubungi Kami</h2>
    </div>
    <div class="contact-grid">
      <div class="contact-info reveal">
        <h3>Ratu Massage & Beauty</h3>

        <div class="contact-row">
          <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <div>
            <strong>Alamat</strong>
            <span>Jl. Raya Pajajaran, RT.01/RW.04, Babakan, Kec. Bogor Tengah, Kota Bogor, Jawa Barat 16129</span>
          </div>
        </div>

        <div class="contact-row">
          <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <div>
            <strong>Telepon / WhatsApp</strong>
            <a href={waLink} target="_blank" rel="noopener noreferrer">0889-2286-721</a>
          </div>
        </div>

        <div class="contact-row">
          <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <div>
            <strong>Jam Operasional</strong>
            <span>24 Jam Nonstop, Setiap Hari</span>
          </div>
        </div>

        <div class="contact-row">
          <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <div>
            <strong>Rating Google</strong>
            <span>5.0 &#9733; (15 ulasan)</span>
          </div>
        </div>

        <a href={mapsLink} class="btn-maps" target="_blank" rel="noopener noreferrer">
          Lihat di Google Maps
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>
      </div>

      <div class="contact-map reveal">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3963.2!2d106.81!3d-6.59!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69c5c18278a50d%3A0x7582c3b6ed09f012!2sJl.+Raya+Pajajaran%2C+Babakan%2C+Kec.+Bogor+Tengah%2C+Kota+Bogor!5e0!3m2!1sid!2sid!4v1"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Lokasi Ratu Massage & Beauty di Google Maps"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .contact-info h3 {
    font-size: 1.4rem;
    margin-bottom: 28px;
  }
  .contact-row {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 14px 0;
  }
  .contact-row svg {
    width: 18px;
    height: 18px;
    stroke: var(--gold);
    stroke-width: 1.5;
    fill: none;
    flex-shrink: 0;
    margin-top: 3px;
  }
  .contact-row strong {
    display: block;
    font-size: 0.82rem;
    color: var(--black);
    font-weight: 600;
    margin-bottom: 2px;
  }
  .contact-row span,
  .contact-row a {
    font-size: 0.88rem;
    color: var(--gray);
  }
  .contact-row a:hover,
  .contact-row a:focus-visible {
    color: var(--gold);
  }
  .btn-maps {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid rgba(0,0,0,0.12);
    color: var(--black);
    padding: 10px 24px;
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: all 0.2s ease;
    margin-top: 24px;
  }
  .btn-maps:hover,
  .btn-maps:focus-visible {
    border-color: var(--gold);
    color: var(--gold);
  }
  .contact-map {
    border-radius: 8px;
    overflow: hidden;
    height: 100%;
    min-height: 380px;
  }
  .contact-map iframe {
    width: 100%;
    height: 100%;
    min-height: 380px;
    border: 0;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .contact-info h3 {
      font-size: 1.2rem;
      margin-bottom: 20px;
    }
    .contact-map {
      min-height: 280px;
    }
    .contact-map iframe {
      min-height: 280px;
    }
  }
</style>
