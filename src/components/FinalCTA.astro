---
const waLink = 'https://wa.me/628892286721?text=Halo%20Ratu%20Massage%2C%20saya%20ingin%20booking%20massage%20panggilan.%20Bisa%20info%20jadwal%20%26%20harganya%3F';
---

<section class="final-cta" id="booking">
  <div class="container reveal">
    <h2>Siap Untuk Relaksasi?</h2>
    <p>Booking sekarang dan rasakan kenyamanan spa premium langsung di rumah Anda.</p>
    <a href={waLink} class="btn-final" target="_blank" rel="noopener noreferrer">
      Hubungi Kami
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<style>
  .final-cta {
    padding: 64px 0;
    text-align: center;
    background: var(--white);
  }
  .final-cta h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    margin-bottom: 12px;
  }
  .final-cta p {
    font-size: 0.92rem;
    margin-bottom: 28px;
    max-width: 420px;
    margin-left: auto;
    margin-right: auto;
  }
  .btn-final {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--gold);
    color: var(--white);
    padding: 14px 40px;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: all 0.3s ease;
    border: none;
  }
  .btn-final:hover,
  .btn-final:focus-visible {
    background: var(--gold-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(212, 165, 74, 0.4);
  }
</style>
