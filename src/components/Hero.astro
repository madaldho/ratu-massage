---
const waLink = 'https://wa.me/628892286721?text=Halo%20Ratu%20Massage%2C%20saya%20tertarik%20booking%20massage%20panggilan';
---

<section class="hero" id="hero">
  <div class="hero-bg">
    <img src="/assets/hero-massage.png" alt="Ratu Massage & Beauty — Massage Panggilan Profesional di Bogor" width="1920" height="1080" />
  </div>
  <div class="hero-overlay"></div>
  <div class="container">
    <div class="hero-content">
      <h1 class="reveal">Relaksasi Premium<br />di Rumah Anda</h1>
      <p class="hero-sub reveal">Massage panggilan profesional 24 jam di Bogor dan sekitarnya. Terapis bersertifikat datang langsung ke rumah atau hotel Anda.</p>
      <a href={waLink} class="hero-cta reveal" target="_blank" rel="noopener noreferrer">
        Booking Sekarang
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
  <div class="hero-scroll" aria-hidden="true">
    <span>Scroll</span>
    <div class="hero-scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(26, 26, 26, 0.78) 0%,
      rgba(26, 26, 26, 0.55) 50%,
      rgba(26, 26, 26, 0.3) 100%
    );
    z-index: 1;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 600px;
    padding: 140px 0 100px;
  }
  .hero h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    color: var(--white);
    font-weight: 600;
    margin-bottom: 20px;
    line-height: 1.1;
  }
  .hero-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 460px;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--gold);
    color: var(--gold);
    padding: 14px 36px;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .hero-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    z-index: -1;
    border-radius: 100px;
  }
  .hero-cta:hover::before,
  .hero-cta:focus-visible::before {
    transform: scaleX(1);
    transform-origin: left;
  }
  .hero-cta:hover,
  .hero-cta:focus-visible {
    color: var(--black);
    border-color: var(--gold);
  }
  .hero-scroll {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.4);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .hero-scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
    animation: scrollPulse 2s ease infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.8; }
  }

  @media (max-width: 768px) {
    .hero-content {
      padding: 120px 0 80px;
    }
    .hero h1 {
      font-size: clamp(1.8rem, 7vw, 2.6rem);
    }
    .hero-sub {
      font-size: 0.92rem;
      margin-bottom: 28px;
    }
    .hero-cta {
      padding: 12px 28px;
      font-size: 0.75rem;
    }
    .hero-scroll {
      bottom: 24px;
    }
  }
  @media (max-width: 380px) {
    .hero-content {
      padding: 100px 0 60px;
    }
    .hero h1 {
      font-size: 1.7rem;
    }
  }
</style>
